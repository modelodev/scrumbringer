    ".assignments-toolbar-card { padding: 10px 12px; margin-bottom: 12px; }",
    ".assignments-toolbar { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }",
    ".assignments-toggle-field { min-width: 260px; }",
    ".assignments-toggle { width: 100%; }",
    ".assignments-toggle .view-mode-btn { flex: 1; justify-content: center; min-height: 34px; padding: 6px 12px; }",
    ".assignments-search input { min-width: 240px; width: 100%; }",
    ".assignments-search { min-width: 260px; flex: 1 1 280px; }",
    ".assignments-table { margin-top: 4px; }",
    ".assignments-table th:first-child, .assignments-table td:first-child { padding-left: 12px; }",
    ".assignments-table th:last-child, .assignments-table td:last-child { padding-right: 12px; }",
    ".assignments-table-row > td { vertical-align: middle; }",
    ".assignments-primary-cell { width: 100%; }",
    ".assignments-meta-cell { white-space: nowrap; text-align: right; font-size: var(--sb-font-sm); color: var(--sb-muted); font-weight: var(--sb-weight-medium); font-variant-numeric: tabular-nums; }",
    ".assignments-card-title { display: flex; align-items: center; gap: 8px; font-weight: var(--sb-weight-semibold); min-width: 0; line-height: var(--sb-line-title); }",
    ".assignments-card-icon { display: inline-flex; }",
    ".assignments-card-title .badge { margin-left: 2px; }",
    ".assignments-card-body { display: flex; flex-direction: column; gap: 8px; margin-left: 0; border-left: 0; padding: 10px 0 0; }",
    ".assignments-card-body.expansion-content { background: color-mix(in oklab, var(--sb-primary) 4%, var(--sb-surface)); border: 1px solid color-mix(in oklab, var(--sb-primary) 32%, var(--sb-border)); border-radius: 10px; padding: 12px; margin: 6px 0 0; }",
    ".assignments-rows { display: flex; flex-direction: column; gap: 0; border: 1px solid var(--sb-border); border-radius: 10px; overflow: hidden; background: var(--sb-surface); }",
    ".assignments-row { display: grid; grid-template-columns: minmax(220px, 1fr) auto auto; align-items: center; gap: 8px; padding: 8px 10px; border-bottom: 1px solid var(--sb-border); background: var(--sb-surface); }",
    ".assignments-row:last-child { border-bottom: none; }",
    ".assignments-row-title { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }",
    ".assignments-row-actions { display: flex; gap: 6px; align-items: center; }",
    ".assignments-metrics { display: flex; flex-wrap: wrap; gap: 8px; margin: 8px 0; }",
    ".assignments-metrics-item { font-size: var(--sb-font-sm); color: color-mix(in oklab, var(--sb-text) 82%, var(--sb-muted)); background: color-mix(in oklab, var(--sb-elevated) 85%, var(--sb-surface)); border: 1px solid color-mix(in oklab, var(--sb-border) 70%, var(--sb-text)); border-radius: 999px; padding: 4px 8px; }",
    ".assignments-inline-add { margin-top: 10px; padding: 10px; border-radius: 10px; border: 1px solid var(--sb-border); background: var(--sb-elevated); }",
    ".assignments-inline-add-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }",
    ".assignments-inline-add-label { font-size: var(--sb-font-sm); color: var(--sb-muted); }",
    ".assignments-inline-add-actions { display: flex; gap: 6px; }",
    ".assignments-card-body > .btn-sm { margin-top: 8px; }",
    ".assignments-inline-add input, .assignments-inline-add select, .assignments-row select { min-height: 32px; }",
    ".assignments-empty { color: var(--sb-muted); font-size: var(--sb-font-base); }",
    "@media (max-width: 768px) { .assignments-toolbar-card { padding: 8px 10px; } .assignments-toolbar { align-items: stretch; } .assignments-toggle-field, .assignments-search { min-width: 0; width: 100%; } .assignments-table thead { position: absolute; top: -9999px; left: -9999px; } .assignments-table tbody tr.assignments-table-row { display: block; padding: 10px 0; } .assignments-table tbody tr.assignments-table-row td { display: block; width: 100%; border: 0; padding: 4px 0; } .assignments-meta-cell { text-align: left; } .assignments-row { grid-template-columns: 1fr; align-items: stretch; } .assignments-row-title { white-space: normal; } .assignments-row select { width: 100%; } .assignments-row-actions { width: 100%; justify-content: flex-end; } }",
  ]
}
