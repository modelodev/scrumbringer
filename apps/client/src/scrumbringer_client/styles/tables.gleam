    ".rule-row-expandable:hover { background: var(--sb-elevated); border-color: color-mix(in oklab, var(--sb-primary) 28%, var(--sb-border)); }",
    ".rule-row-expandable:focus-visible { outline: 2px solid var(--sb-primary); outline-offset: 2px; }",
    ".rule-row-expanded { background: var(--sb-surface); border-color: color-mix(in oklab, var(--sb-primary) 34%, var(--sb-border)); }",
    // AC2: Prevent row click on actions column
