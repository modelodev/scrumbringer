    ".task-type-inline svg { width: 14px; height: 14px; }",
    ".cell-rule-sentence { min-width: 260px; }",
    ".automation-rule-sentence { display: flex; flex-direction: column; gap: 3px; min-width: 0; line-height: var(--sb-line-body); }",
